<script>
  const slider = document.getElementById('robuxSlider');
  const robuxOut = document.getElementById('robuxOut');
  const priceOut = document.getElementById('priceOut');
  const note = document.getElementById('calcNote');

  function format(num){
    return num.toLocaleString('en-US');
  }

  function update(){
    const robux = parseInt(slider.value, 10);
    let total;
    if(robux >= 10000){
      total = (robux / 1000) * 120;
      note.innerHTML = '<span class="on">Tarifa mayorista activa:</span> $120 MXN por cada 1,000 R$ (10,000+).';
    } else {
      total = (robux / 1000) * 150;
      const faltan = 10000 - robux;
      note.innerHTML = 'Tarifa estándar: $150 MXN por cada 1,000 R$. Pide ' + format(faltan) + ' R$ más para activar el precio mayorista de $120/1k.';
    }
    robuxOut.innerHTML = format(robux) + '<span> R$</span>';
    priceOut.innerHTML = '$' + format(Math.round(total)) + '<span> MXN</span>';
  }

  slider.addEventListener('input', update);
  update();
</script>

