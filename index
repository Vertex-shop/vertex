<style>
  :root{
    --bg: #0b0f0d;
    --bg-soft: #111613;
    --panel: #161d19;
    --line: #243029;
    --lime: #c8ff4d;
    --gold: #ffd166;
    --text: #eef2ee;
    --text-dim: #9bab9f;
    --mono: 'JetBrains Mono', 'SF Mono', Consolas, monospace;
    --display: 'Space Grotesk', Arial, sans-serif;
  }

  *{ margin:0; padding:0; box-sizing:border-box; }

  html{ scroll-behavior: smooth; }

  body{
    background: var(--bg);
    color: var(--text);
    font-family: var(--display);
    -webkit-font-smoothing: antialiased;
    line-height: 1.5;
  }

  a{ color: inherit; text-decoration: none; }

  /* ---------- NAV ---------- */
  header{
    position: sticky; top:0; z-index: 50;
    display:flex; align-items:center; justify-content:space-between;
    padding: 18px 6%;
    background: rgba(11,15,13,0.85);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .logo{
    font-family: var(--mono);
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.12em;
    display:flex; align-items:center; gap:10px;
  }
  .logo .dot{
    width:10px; height:10px; border-radius:2px;
    background: var(--lime);
    box-shadow: 0 0 12px var(--lime);
  }
  nav{ display:flex; gap: 28px; font-size: 0.92rem; color: var(--text-dim); }
  nav a:hover{ color: var(--lime); }

  /* ---------- HERO ---------- */
  .hero{
    padding: 90px 6% 60px;
    display:grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 50px;
    align-items: center;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .hero::before{
    content:"";
    position:absolute; inset:0;
    background:
      radial-gradient(circle at 80% 20%, rgba(200,255,77,0.08), transparent 40%),
      repeating-linear-gradient(90deg, transparent, transparent 79px, var(--line) 80px);
    opacity:0.5;
    pointer-events:none;
  }
  .eyebrow{
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    color: var(--lime);
    text-transform: uppercase;
    margin-bottom: 18px;
    display:flex; align-items:center; gap:10px;
  }
  .eyebrow::before{
    content:"●"; font-size: 0.6rem; animation: pulse 1.6s infinite;
  }
  @keyframes pulse{ 50%{ opacity:0.25; } }

  h1{
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  h1 span{ color: var(--lime); }

  .hero p.sub{
    margin-top: 18px;
    color: var(--text-dim);
    font-size: 1.05rem;
    max-width: 480px;
  }
  .hero-ctas{ display:flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }

  .btn{
    font-family: var(--mono);
    font-size: 0.88rem;
    padding: 14px 26px;
    border-radius: 6px;
    font-weight: 600;
    letter-spacing: 0.04em;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    display:inline-flex; align-items:center; gap:8px;
    border: 1px solid transparent;
  }
  .btn:hover{ transform: translateY(-2px); }
  .btn-primary{ background: var(--lime); color: #0b0f0d; box-shadow: 0 0 0 0 transparent; }
  .btn-primary:hover{ box-shadow: 0 6px 24px rgba(200,255,77,0.25); }
  .btn-outline{ border-color: var(--line); color: var(--text); }
  .btn-outline:hover{ border-color: var(--lime); color: var(--lime); }

  /* ---------- TICKER ---------- */
  .ticker-wrap{
    background: var(--bg-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    overflow: hidden;
    white-space: nowrap;
    padding: 10px 0;
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--text-dim);
  }
  .ticker{
    display:inline-block;
    animation: scroll 28s linear infinite;
  }
  .ticker span{ margin: 0 28px; }
  .ticker .up{ color: var(--lime); }
  @keyframes scroll{
    from{ transform: translateX(0); }
    to{ transform: translateX(-50%); }
  }

  /* ---------- CALCULADORA (signature) ---------- */
  .calc{
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 32px;
    position: relative;
    z-index: 2;
  }
  .calc-head{
    display:flex; justify-content:space-between; align-items:baseline;
    margin-bottom: 24px;
  }
  .calc-head h3{ font-size: 1.05rem; letter-spacing: 0.04em; }
  .calc-head .badge{
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--lime);
    border: 1px solid var(--lime);
    padding: 4px 10px;
    border-radius: 99px;
    letter-spacing: 0.08em;
  }

  .calc-display{
    display:flex; justify-content:space-between; align-items:flex-end;
    font-family: var(--mono);
    margin-bottom: 22px;
  }
  .calc-display .robux-amount{
    font-size: 2.4rem; font-weight: 700;
  }
  .calc-display .robux-amount span{ font-size: 1rem; color: var(--text-dim); font-weight:400; }
  .calc-display .price-amount{
    font-size: 2.4rem; font-weight: 700; color: var(--gold);
    text-align: right;
  }
  .calc-display .price-amount span{ font-size: 1rem; color: var(--text-dim); font-weight:400; }

  input[type="range"]{
    width: 100%;
    -webkit-appearance: none;
    height: 4px;
    background: var(--line);
    border-radius: 99px;
    outline: none;
    margin: 6px 0 8px;
  }
  input[type="range"]::-webkit-slider-thumb{
    -webkit-appearance: none;
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--lime);
    border: 4px solid var(--bg);
    box-shadow: 0 0 0 1px var(--line);
    cursor: pointer;
  }
  input[type="range"]::-moz-range-thumb{
    width: 20px; height: 20px;
    border-radius: 50%;
    background: var(--lime);
    border: 4px solid var(--bg);
    cursor: pointer;
  }

  .calc-scale{
    display:flex; justify-content:space-between;
    font-family: var(--mono); font-size: 0.72rem; color: var(--text-dim);
    margin-bottom: 18px;
  }

  .calc-note{
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-dim);
    border-top: 1px dashed var(--line);
    padding-top: 14px;
    margin-bottom: 22px;
    min-height: 1.4em;
  }
  .calc-note .on{ color: var(--gold); }

  .calc .btn{ width: 100%; justify-content: center; }

  /* ---------- SECTIONS ---------- */
  section{ padding: 80px 6%; border-bottom: 1px solid var(--line); }
  .section-head{ margin-bottom: 48px; max-width: 600px; }
  .section-head .eyebrow{ margin-bottom: 12px; }
  .section-head h2{ font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; }
  .section-head p{ color: var(--text-dim); margin-top: 12px; }

  /* PRICING TABLE */
  .price-table{
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
  }
  .price-row{
    display:grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    align-items:center;
    padding: 20px 28px;
    border-bottom: 1px solid var(--line);
    gap: 20px;
  }
  .price-row:last-child{ border-bottom: none; }
  .price-row.head{
    background: var(--bg-soft);
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .price-row .qty{ font-weight: 700; font-size: 1.1rem; }
  .price-row .qty small{ color: var(--text-dim); font-weight:400; font-size: 0.8rem; }
  .price-row .rate{ font-family: var(--mono); color: var(--text-dim); }
  .price-row .total{ font-family: var(--mono); font-size: 1.2rem; color: var(--gold); font-weight:700; }
  .price-row .tag{
    font-family: var(--mono); font-size: 0.7rem;
    padding: 4px 10px; border-radius: 99px;
    border: 1px solid var(--line); color: var(--text-dim);
    width: fit-content;
  }
  .price-row .tag.best{ border-color: var(--lime); color: var(--lime); }

  /* PRODUCTS GRID */
  .grid{
    display:grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 20px;
  }
  .card{
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 26px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .card:hover{ border-color: var(--lime); transform: translateY(-3px); }
  .card .icon{ font-size: 1.8rem; margin-bottom: 14px; display:block; }
  .card h4{ font-size: 1.05rem; margin-bottom: 8px; }
  .card p{ color: var(--text-dim); font-size: 0.9rem; }
  .card .price{
    font-family: var(--mono); color: var(--gold);
    margin-top: 14px; font-size: 0.95rem; font-weight: 600;
  }

  /* CTA BAND */
  .cta-band{
    text-align:center;
    padding: 90px 6%;
    background:
      radial-gradient(circle at 50% 0%, rgba(200,255,77,0.07), transparent 60%),
      var(--bg-soft);
    border-bottom: 1px solid var(--line);
  }
  .cta-band h2{ font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 14px; }
  .cta-band p{ color: var(--text-dim); margin-bottom: 32px; max-width: 520px; margin-inline:auto; }
  .cta-row{ display:flex; gap:14px; justify-content:center; flex-wrap: wrap; }

  .order-card{
    max-width: 640px;
    margin: 40px auto 0;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 32px;
    text-align: left;
  }
  .order-step{
    display:flex; gap: 16px; align-items:flex-start;
    padding: 16px 0;
    border-bottom: 1px solid var(--line);
  }
  .order-step:last-child{ border-bottom: none; }
  .order-step .num{
    font-family: var(--mono); color: var(--lime);
    font-weight:700; font-size: 0.9rem;
    border: 1px solid var(--line);
    border-radius: 6px; padding: 4px 10px;
    flex-shrink:0;
  }
  .order-step .body strong{ display:block; margin-bottom: 4px; font-size: 0.98rem; }
  .order-step .body span{ color: var(--text-dim); font-size: 0.88rem; }

  /* FAQ */
  details{
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 18px 22px;
    margin-bottom: 12px;
    background: var(--panel);
  }
  summary{
    cursor:pointer;
    font-weight: 600;
    display:flex; justify-content:space-between; align-items:center;
    list-style:none;
  }
  summary::-webkit-details-marker{ display:none; }
  summary::after{ content:"+"; font-family: var(--mono); color: var(--lime); font-size:1.2rem; }
  details[open] summary::after{ content:"−"; }
  details p{ color: var(--text-dim); margin-top: 12px; font-size: 0.92rem; }

  /* FOOTER */
  footer{
    padding: 40px 6%;
    display:flex; justify-content:space-between; align-items:center;
    flex-wrap: wrap; gap: 16px;
    font-family: var(--mono);
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  footer a:hover{ color: var(--lime); }

  @media (max-width: 860px){
    .hero{ grid-template-columns: 1fr; padding-top: 60px; }
    .price-row{ grid-template-columns: 1fr 1fr; }
    .price-row .rate, .price-row .tag{ display:none; }
    nav{ display:none; }
  }
</style>
</head>
